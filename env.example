# Copy to .env.local and fill in your values. Never commit .env.local.

# Google OAuth (from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Get refresh token once via /auth flow, then paste here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
# Optional: access token and expiry (server auto-refreshes from refresh token)
# GOOGLE_ACCESS_TOKEN=
# GOOGLE_TOKEN_EXPIRY=

# Site URL (e.g. https://lotusfx.com or your Vercel URL)
NEXT_PUBLIC_SITE_URL=http://localhost:8004

# Exchange rate API (per country - get from your backend)
# EXCHANGE_RATE_API_URL_AU=
# EXCHANGE_RATE_X_KEY_AU=
# EXCHANGE_RATE_X_CLIENT_AU=
# (same for NZ, FJ)